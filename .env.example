# ═══════════════════════════════════════════════════════════════════════════
# MarketMind AI - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════

# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/product_intelligence.db
# For production, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/marketmind

# ─── LLM / Ollama ──────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b
OLLAMA_TIMEOUT=120

# ─── Google Ads Keyword Planner API (Tier 1 - Most Accurate) ──────────────
# Get credentials from: https://ads.google.com/home/tools/manager-accounts/
# Follow guide: https://developers.google.com/google-ads/api/docs/first-call/overview
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ─── SerpAPI (Tier 2 - Keyword Research Fallback) ─────────────────────────
# Get free API key from: https://serpapi.com/
# Free tier: 100 searches/month
SERPAPI_KEY=

# ─── Reddit API (Trend Scouting - Optional) ────────────────────────────────
# Create app at: https://www.reddit.com/prefs/apps
# Choose "script" type
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=MarketMindAI/1.0

# ═══════════════════════════════════════════════════════════════════════════
# NOTES:
# ═══════════════════════════════════════════════════════════════════════════
# 
# 1. Keyword Research works in 3 tiers (cascading fallback):
#    - Tier 1: Google Ads API (most accurate, requires setup)
#    - Tier 2: SerpAPI (easy, 100 free searches/month)
#    - Tier 3: Direct SERP scraping (no key needed, less accurate)
#
# 2. Trend Scouting works with or without Reddit API:
#    - With Reddit: Gets trending product discussions
#    - Without Reddit: Uses Google Trends + Amazon Movers only
#
# 3. All other data sources require NO API keys:
#    - Google Trends (pytrends)
#    - Amazon scraping (direct HTTP)
#    - Alibaba/AliExpress scraping (direct HTTP)
#    - Exchange rates (free API)
#
# 4. Ollama must be running locally:
#    - Install from: https://ollama.com
#    - Run: ollama pull llama3:8b
#    - Start: ollama serve
#
# ═══════════════════════════════════════════════════════════════════════════
